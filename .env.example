# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/trackbite

# ─── Server ──────────────────────────────────────────────────────────────────
# Hostinger sets this automatically — do NOT override unless you know what you're doing
PORT=3000

# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Gmail account that sends demo request notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
# Use a Gmail App Password (NOT your normal password):
# https://myaccount.google.com/apppasswords
SMTP_PASS=your-16-char-app-password

# Email address that receives demo request notifications
DEMO_NOTIFICATION_EMAIL=support@trackbite.in

# ─── Session ─────────────────────────────────────────────────────────────────
# A long random string used to sign session cookies (generate one with: openssl rand -base64 32)
SESSION_SECRET=change-this-to-a-long-random-string

# ─── Node ────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
